<?xml version="1.0" encoding="UTF-8"?>
<!-- Version endpoint for the Otzar Hachochma kiosk self-updater.
     Served by GitHub Pages at https://shalom-karr.github.io/otzar-hachochma-filter/version.xml
     The updater reads <version>; if it is newer than the local $KioskVersion in setup.ps1 it
     downloads the scripts from Pages (or the branch zip) and re-runs.
     Bump BOTH this <version> and $KioskVersion in setup.ps1 on every release. -->
<otzarKiosk>
  <version>1.3.3</version>
  <name>Otzar Hachochma Filter</name>
  <updated>2026-07-13</updated>
  <pages>https://shalom-karr.github.io/otzar-hachochma-filter</pages>
  <zipUrl>https://github.com/Shalom-Karr/otzar-hachochma-filter/archive/refs/heads/main.zip</zipUrl>
  <repo>https://github.com/Shalom-Karr/otzar-hachochma-filter</repo>
</otzarKiosk>
